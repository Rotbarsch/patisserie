<section class="testimonials-section">
    <div class="section-header">
        <h2 class="section-title">Kundenstimmen</h2>
        <div class="section-divider" aria-hidden="true">
            <span class="divider-line"></span>
            <span class="divider-dot">✦</span>
            <span class="divider-line"></span>
        </div>
    </div>

    @if (Items is not null)
    {
        <ul class="testimonials-grid">
            @foreach (var item in Items)
            {
                <li class="testimonial-card">
                    <span class="testimonial-quote-mark" aria-hidden="true">„</span>
                    <blockquote class="testimonial-text">@item.Quote</blockquote>
                    <footer class="testimonial-author">— @item.Author</footer>
                </li>
            }
        </ul>
    }
</section>
