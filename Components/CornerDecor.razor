<span class="corner-decor corner-decor--@Position" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 160" fill="none"
         stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <g stroke-width="0.9">
            <!-- L-bracket arms -->
            <line x1="56" y1="10" x2="148" y2="10" />
            <line x1="10" y1="56" x2="10" y2="148" />

            <!-- Arc connecting the two arms -->
            <path d="M56,10 C40,10 10,40 10,56" />

            <!-- Botanical scroll at the corner junction -->
            <!-- Main vine: sweeps from top-arm, loops around the corner, spirals inward -->
            <path d="M48,12 C38,8 18,10 12,22 C6,36 14,50 28,48 C42,46 48,32 40,24 C32,16 20,20 18,30 C16,40 24,46 32,42" />
            <!-- Secondary inner tendril -->
            <path d="M24,28 C20,22 22,16 28,16 C34,16 36,22 32,28 C28,34 22,34 22,28" />
            <!-- Small curling offshoot toward the connecting arc -->
            <path d="M36,40 C40,44 38,50 34,48" />
            <!-- Tiny leaf from the outer vine -->
            <path d="M20,18 C14,14 12,20 16,22" />

            <!-- Paired leaf accents on top arm -->
            <path d="M80,10 C78,5 72,7 76,12 M80,10 C82,5 88,7 84,12" />
            <path d="M114,10 C112,5 106,7 110,12 M114,10 C116,5 122,7 118,12" />

            <!-- Paired leaf accents on left arm -->
            <path d="M10,80 C5,78 7,72 12,76 M10,80 C5,82 7,88 12,84" />
            <path d="M10,114 C5,112 7,106 12,110 M10,114 C5,116 7,122 12,118" />

            <!-- Terminal dots at arm tips -->
            <circle cx="148" cy="10" r="2" fill="currentColor" stroke="none" />
            <circle cx="10" cy="148" r="2" fill="currentColor" stroke="none" />

            <!-- Junction dots where the arc meets the arms -->
            <circle cx="56" cy="10" r="1.5" fill="currentColor" stroke="none" />
            <circle cx="10" cy="56" r="1.5" fill="currentColor" stroke="none" />
        </g>
    </svg>
</span>

@code {
    /// <summary>Corner position: tl, tr, bl, br</summary>
    [Parameter] public string Position { get; set; } = "tl";
}
