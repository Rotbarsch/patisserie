<span class="corner-decor corner-decor--@Position" aria-hidden="true">
    <!--
        TL orientation. TR = scaleX(-1), BL = scaleY(-1), BR = rotate(180deg).
        Frame inset is 10px, so arm stubs sit at x=10 and y=10 to meet the CSS border.
    -->
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 150 150" fill="none"
         stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
        <g stroke-width="0.85">

            <!-- Arm stubs: reinforce the CSS page-frame border near the corner -->
            <line x1="10" y1="10" x2="115" y2="10" />
            <line x1="10" y1="10" x2="10" y2="115" />

            <!-- ── Baroque scroll cluster ──────────────────────────────
                 Three interlocking C-scroll loops, largest → smallest,
                 cascading diagonally from upper-right toward lower-left.
            ─────────────────────────────────────────────────────────── -->

            <!-- Scroll A – largest, upper-right of cluster -->
            <path d="M 70,14
                     C 56, 8  38,10  34,22
                     C 30,34  40,44  52,40
                     C 64,36  68,24  58,18
                     C 48,12  36,16  38,28" />

            <!-- Scroll B – medium, centre of cluster -->
            <path d="M 44,24
                     C 34,18  20,22  18,34
                     C 16,46  26,54  38,50
                     C 50,46  52,34  42,28
                     C 32,22  22,28  24,38" />

            <!-- Scroll C – smallest, lower-left of cluster -->
            <path d="M 22,46
                     C 14,42  10,52  12,62
                     C 14,72  24,76  30,68
                     C 36,60  32,50  24,52
                     C 16,54  14,64  18,70" />

            <!-- ── Leaf / petal accents between scrolls ── -->
            <path d="M 54,16 C 50,10 42,12 44,20" />
            <path d="M 32,32 C 26,26 18,30 20,38" />
            <path d="M 14,60 C  8,56  6,64  10,68" />

            <!-- ── Outward tendrils at scroll tips ── -->
            <path d="M 70,22 C 78,18 82,26 76,30" />
            <path d="M 20,72 C 16,80 20,86 26,84" />

            <!-- Small connector from cluster to arm stubs -->
            <path d="M 70,14 C 80,12 98,10 115,10" stroke-width="0.6" opacity="0.7" />
            <path d="M 22,70 C 14,80 10,98 10,115" stroke-width="0.6" opacity="0.7" />

            <!-- Terminal dots at arm ends -->
            <circle cx="115" cy="10" r="2"   fill="currentColor" stroke="none" />
            <circle cx="10"  cy="115" r="2"   fill="currentColor" stroke="none" />

            <!-- Small dot at frame corner junction -->
            <circle cx="10" cy="10" r="1.6" fill="currentColor" stroke="none" />

        </g>
    </svg>
</span>

@code {
    /// <summary>Corner position: tl | tr | bl | br</summary>
    [Parameter] public string Position { get; set; } = "tl";
}
