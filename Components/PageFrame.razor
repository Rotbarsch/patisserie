<div class="page-frame-wrapper" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <defs>
            <!--
                Corner ornament drawn with (0,0) at the frame-line junction.
                Extends into positive x,y (~55×65 px).
                All four corners reuse this via <use> + CSS transform.
            -->
            <g id="corner-orn"
               fill="none" stroke="currentColor"
               stroke-linecap="round" stroke-linejoin="round">

                <!-- Junction dot at the frame-line corner -->
                <circle cx="0" cy="0" r="1.5" fill="currentColor" stroke="none"/>

                <!--
                    MAIN VOLUTE — a 1.5-turn baroque scroll.
                    Starts near the horizontal arm (x≈50, y≈3),
                    sweeps outward in a large arc, spirals back
                    through two nested loops, terminating at ~(20,34).
                -->
                <path d="M 50,3
                         C 62,3 68,20 62,36
                         C 56,52 40,60 24,56
                         C 8,52 2,38 6,24
                         C 10,10 22,4 34,8
                         C 46,12 50,26 44,36
                         C 38,46 24,48 14,42
                         C 4,36 4,22 12,16
                         C 20,10 32,12 34,22
                         C 36,32 28,38 20,34"
                      stroke-width="0.9"/>

                <!-- Small outward tendril at the volute tip -->
                <path d="M 20,34 C 16,40 20,46 26,42" stroke-width="0.75"/>

                <!-- Terminal curl at the horizontal arm end -->
                <path d="M 52,1 C 57,-1 63,5 59,12 C 55,18 48,14 50,7"
                      stroke-width="0.8"/>

                <!-- Terminal curl at the vertical arm end -->
                <path d="M 1,52 C -1,57 5,63 12,59 C 18,55 14,48 7,50"
                      stroke-width="0.8"/>

                <!-- Leaf accents along the horizontal arm (y≈0) -->
                <path d="M 26,0 C 22,6 17,5 19,1" stroke-width="0.7"/>
                <path d="M 36,0 C 32,6 27,5 29,1" stroke-width="0.7"/>

                <!-- Leaf accents along the vertical arm (x≈0) -->
                <path d="M 0,26 C 6,22 5,17 1,19" stroke-width="0.7"/>
                <path d="M 0,36 C 6,32 5,27 1,29" stroke-width="0.7"/>
            </g>
        </defs>

        <!--
            Frame rectangle — 15 px inset from every viewport edge.
            CSS calc() on SVG geometry properties is supported in all
            modern browsers (Chrome 66+, Firefox 62+, Safari 12+).
        -->
        <rect style="x:15px; y:15px; width:calc(100% - 30px); height:calc(100% - 30px)"
              fill="none" stroke="currentColor" stroke-width="0.75"/>

        <!-- TL — origin -->
        <use href="#corner-orn" style="transform: translate(15px, 15px)"/>
        <!-- TR — mirror horizontally -->
        <use href="#corner-orn" style="transform: translate(calc(100% - 15px), 15px) scale(-1, 1)"/>
        <!-- BL — mirror vertically -->
        <use href="#corner-orn" style="transform: translate(15px, calc(100% - 15px)) scale(1, -1)"/>
        <!-- BR — mirror both -->
        <use href="#corner-orn" style="transform: translate(calc(100% - 15px), calc(100% - 15px)) scale(-1, -1)"/>
    </svg>
</div>
