<div class="page-frame-wrapper" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block">
        <defs>
            <g id="corner-orn"
               fill="none" stroke="currentColor"
               stroke-linecap="round" stroke-linejoin="round">
                <circle cx="0" cy="0" r="1.5" fill="currentColor" stroke="none"/>
                <path d="M 44,0 C 44,18 18,44 0,44" stroke-width="0.85"/>
                <path d="M 44,0 C 50,-1 54,6 49,11 C 44,16 38,12 41,7" stroke-width="0.75"/>
                <path d="M 0,44 C -1,50 6,54 11,49 C 16,44 12,38 7,41" stroke-width="0.75"/>
                <path d="M 40,14 C 36,21 29,20 31,14" stroke-width="0.65"/>
                <path d="M 14,40 C 21,36 20,29 14,31" stroke-width="0.65"/>
                <circle cx="29" cy="29" r="1" fill="currentColor" stroke="none"/>
            </g>
        </defs>

        <!-- Border rect at the site-wrapper edge -->
        <rect x="0.375" y="0.375" width="calc(100% - 0.75px)" height="calc(100% - 0.75px)"
              fill="none" stroke="currentColor" stroke-width="0.75"/>

        <!-- TL -->
        <svg x="0" y="0" overflow="visible">
            <use href="#corner-orn"/>
        </svg>
        <!-- TR -->
        <svg x="100%" y="0" overflow="visible">
            <use href="#corner-orn" transform="scale(-1,1)"/>
        </svg>
        <!-- BL -->
        <svg x="0" y="100%" overflow="visible">
            <use href="#corner-orn" transform="scale(1,-1)"/>
        </svg>
        <!-- BR -->
        <svg x="100%" y="100%" overflow="visible">
            <use href="#corner-orn" transform="scale(-1,-1)"/>
        </svg>
    </svg>
</div>
